{
  "name": "@rms/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @rms/shared build && pnpm prisma:generate && tsx watch src/index.ts",
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "start": "pnpm --filter @rms/shared build && pnpm prisma:generate && node dist/index.js",
    "lint": "echo 'No lint configured for api'",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:init": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script | prisma db execute --stdin",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@rms/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
