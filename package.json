{
  "name": "rms-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "pnpm --filter @rms/api dev",
    "dev:web": "pnpm --filter @rms/web dev",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "pnpm -r --if-present format",
    "db:init": "pnpm --filter @rms/api db:init",
    "db:seed": "pnpm --filter @rms/api seed"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
